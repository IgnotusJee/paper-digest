# Copy to .env and fill in values. Never commit .env.

# MySQL
MYSQL_DATABASE=paper_digest
MYSQL_USER=pd_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_PORT=3306

# Backend
DATABASE_URL=mysql+asyncmy://pd_user:CHANGE_ME@mysql:3306/paper_digest
JWT_SECRET=                # openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=            # strong password; only used once at init_db
BASE_URL=https://paper.yourdomain.com

# Frontend (Nginx)
FRONTEND_PORT=80

# SMTP (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_FROM="Paper Digest <digest@example.com>"

# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_INPUT_COST_PER_1M=0.5
DEEPSEEK_OUTPUT_COST_PER_1M=1.5
