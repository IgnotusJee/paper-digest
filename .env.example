# Copy to .env and fill in values. Never commit .env.
DATABASE_URL=mysql+asyncmy://pd_user:CHANGE_ME@mysql_container_name:3306/paper_digest
JWT_SECRET=  # openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=  # strong password; only used once at init_db
BASE_URL=https://paper.yourdomain.com
MYSQL_NETWORK=bridge  # docker network ls -> name of the network where MySQL container lives
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_FROM="Paper Digest <digest@example.com>"
